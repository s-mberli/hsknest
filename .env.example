# Copy to .env and fill in. Never commit your real .env.

# Prisma connection string. SQLite file for local dev; a Postgres URL in prod.
DATABASE_URL="file:./dev.db"

# Secret used to sign NextAuth session tokens. Generate a strong value, e.g.:
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"

# Canonical base URL of the app (required in most non-local deployments).
NEXTAUTH_URL="http://localhost:3000"

# Used to build links inside emails (password reset / verification).
# Usually the same as NEXTAUTH_URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seed/refresh starter word lists (German, Chinese, Spanish) on every boot.
# Idempotent — only creates/updates seeded content, never touches user data.
AUTO_SEED="true"

# Optional: real email delivery via Resend (https://resend.com) for password
# reset and email verification. Without a key, links are logged to the
# server console instead of emailed — fine for local dev/self-hosting.
RESEND_API_KEY=""
EMAIL_FROM="noreply@recall-app.com"

# Self-hosted deployments keep this "true" (the default everywhere): no
# trials, no paywall, no Stripe — billing code is fully bypassed.
# ONLY the managed hosted instance sets SELF_HOSTED="false".
SELF_HOSTED="true"

# Hosted instance only (ignored when SELF_HOSTED="true").
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""

# Optional: unlocks the read-only operator page at /mb-admin for the
# account with this email. Unset = the page 404s for everyone.
ADMIN_EMAIL=""

# Optional: cookieless self-hosted Umami analytics. Both must be set for
# the script to load; leave empty to ship no analytics at all.
NEXT_PUBLIC_UMAMI_URL=""
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
